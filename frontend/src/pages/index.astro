---
import BaseLayout from "../layouts/BaseLayout.astro";
import RandomColor from '../components/RandomColor.astro';
import Button from '../components/Button.astro';
import ProjectSlider from "../components/ProjectSlider.svelte";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");

const featured = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Dave — AI Automation Engineer | Python · FastAPI · LLM Integrations"
  description="I build AI-powered automation systems and data pipelines for remote-first companies. Document processing, multi-source data agents, and workflow automation. Available for part-time remote contracts."
>
  <section>
    <h1>
      I build <RandomColor>AI-powered automation systems</RandomColor> that eliminate manual data work for remote-first teams.
    </h1>

    <p>
      I help operations managers and founders at 10–50 person remote companies replace fragile spreadsheet workflows with reliable Python systems, AI data pipelines, and automated reporting — without hiring a full-time engineer.
    </p>

    <p style="text-align: center; margin-top: 1rem;">
      Currently available for part-time remote contracts — 10–20 hrs/week
    </p>

    <p style="text-align: center; margin-top: 1.25rem;">
      <Button href="https://calendly.com/mdhawal94/30min">Book a free 20-min call →</Button>
    </p>
  </section>

  <section>
    <h2>Services</h2>
    <ul>
      <li>
        <strong><RandomColor>AI document processing pipelines</RandomColor></strong> — Extract structured data from invoices, receipts, and scanned documents automatically. Handles typed and scanned files with high accuracy. Built with Python, FastAPI, and LLM integrations.
      </li>
      <li>
        <strong><RandomColor>Multi-source data retrieval agents</RandomColor></strong> — Connect your CRM, spreadsheets, databases, and SaaS tools into a single queryable system. Ask plain-English questions, get instant answers from all your business data.
      </li>
      <li>
        <strong>Reporting and workflow <RandomColor>automation</RandomColor></strong> — Replace manual data consolidation and report generation with automated Python pipelines. Runs on schedule, integrates with your existing tools, sends alerts when something needs attention.
      </li>
    </ul>
  </section>

  <section>
    <h2>Who I work with</h2>
    <p>
      I work exclusively with remote-first companies — primarily in the US, UK, Canada, and Australia. My clients are typically operations managers or founders at 10–50 person companies who are scaling past what spreadsheets can handle.
    </p>
    <p>
      If your team is manually consolidating data from multiple tools, spending hours on reporting that should take minutes, or processing documents by hand — I can automate that workflow with reliable, maintainable Python systems.
    </p>
    <p>
      I’m async-friendly, work across timezones, and communicate clearly in writing. Available for part-time retainer engagements and scoped project work.
    </p>
  </section>

  <section class="projects-section">
    <h2 style="margin-bottom: 0.5rem;"><RandomColor>Featured Projects</RandomColor></h2>

    <ProjectSlider projects={featured} client:load />

    <p style="margin-top: 1rem; text-align: center">
      <Button href="/projects">View all projects →</Button>
    </p>
  </section>

  <style>
    .projects-section {
      overflow-x: hidden;
      padding: 1rem 0;
    }
  </style>

  <section>
    <h2>Core strengths</h2>
    <ul>
      <li>
        <strong><RandomColor>AI data pipelines</RandomColor></strong> — Python-based pipelines that ingest, process, and make business data queryable using LLMs and vector search.
      </li>
      <li>
        <strong>Document processing and <RandomColor>extraction</RandomColor></strong> — Automated extraction of structured data from PDFs, invoices, and scanned documents using OCR and AI.
      </li>
      <li>
        <strong>API integrations and workflow <RandomColor>automation</RandomColor></strong> — Connect disparate SaaS tools, build reliable sync pipelines, and eliminate manual data movement between systems.
      </li>
      <li>
        <strong>Secure <RandomColor>system design</RandomColor></strong> — Input validation, role-based access control, audit logging, and observability built into every system from day one.
      </li>
    </ul>
  </section>

  <section>
    <h2>How I work</h2>
    <p>
      I work async-first — detailed written communication, clear documentation, and no need for overlapping timezones. I’m based in India (IST, UTC+5:30) and regularly work with teams in the US, UK, and Australia.
    </p>
    <p>
      Every system I build is documented, tested, and handed over with enough context for your team to maintain it. I build things to last, not to require ongoing support from me.
    </p>
    <p>
      My background spans firmware engineering, AR/VR systems, and business analysis — which means I think about reliability, edge cases, and failure modes before I think about features.
    </p>
    <p style="text-align: center; margin-top: 1.25rem;">
      <Button href="https://calendly.com/mdhawal94/30min">Book a free 20-min discovery call →</Button>
    </p>
  </section>
</BaseLayout>
