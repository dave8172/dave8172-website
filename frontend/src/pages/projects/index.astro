---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RandomColor from '../../components/RandomColor.astro';
import Button from '../../components/Button.astro';
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
---

<BaseLayout title="Projects">
  <section class="projects">
    <div class="wide-header">
      <h1><RandomColor>Projects</RandomColor></h1>
      <p>
        A selection of automation, reporting, spreadsheet-system, and internal tooling projects that show how I solve practical business workflow problems.
      </p>
      <p>
        These examples are most relevant for startups, agencies, and small teams that need better operations, reporting, and automation without overcomplicating their stack.
      </p>
      <p style="text-align: center; margin-top: 1rem;">
        <Button href="/services">See services →</Button>
      </p>
    </div>

    <div class="grid">
      {projects.map((project) => (
        <a href={`/projects/${project.slug}`} class="project-card">
            <img
            src={project.data.image}
            alt={project.data.title}
            loading="lazy"
            />

            <div class="card-body">
                <h2>{project.data.title}</h2>
                <p>{project.data.description}</p>

                <ul class="tags">
                    {project.data.tags?.map((tag) => (
                    <li>{tag}</li>
                    ))}
                </ul>
            </div>
        </a>
        ))}
    </div>

    <p style="text-align: center; margin-top: 2rem;">
      <Button href="/about">Need something similar for your business? →</Button>
    </p>
  </section>
</BaseLayout>
